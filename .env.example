# Copy to ".env" in this folder and fill in values from:
# Supabase Dashboard → your project → Project Settings → API

# Project URL (https://<project-ref>.supabase.co)
VITE_SUPABASE_URL=

# anon public key (safe for browser; not the service_role key)
VITE_SUPABASE_ANON_KEY=

# Optional aliases (same meaning as above):
# VITE_PUBLIC_SUPABASE_URL=
# VITE_PUBLIC_SUPABASE_ANON_KEY=

# --- Server-side scripts only (scripts/seed_questions.ts etc.) ---
# NEVER commit this key and NEVER prefix it with VITE_ (that would bundle it
# into the browser build). Rotate it immediately if it ever leaks.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=

# --- Google sign-in (only after the Project URL resolves in the browser) ---
# 1) Supabase → Authentication → URL configuration:
#    - Site URL: your app origin, e.g. http://localhost:5173
#    - Additional Redirect URLs: include that origin and production URL
# 2) Google Cloud Console → APIs & Services → Credentials → OAuth client:
#    - Authorized redirect URIs must include:
#      https://<project-ref>.supabase.co/auth/v1/callback
#
# This app uses window.location.origin for email/OAuth redirects in src/pages/Auth.tsx
